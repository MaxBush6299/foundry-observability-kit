# Azure deployment environment example
# Copy this into .azure/<environment-name>/.env (created by `azd env new`)
# and fill in values for your deployment.

AZURE_ENV_NAME=foundry-observability-dev
AZURE_LOCATION=eastus
AZURE_SUBSCRIPTION_ID=<subscription-guid>
AZURE_RESOURCE_GROUP=rg-foundry-observability

# --- Monitoring mode -------------------------------------------------------
# false = create a new Log Analytics workspace + Application Insights (greenfield).
# true  = reuse an existing Application Insights resource (recommended when your
#         Foundry project is already connected to Application Insights).
USE_EXISTING_MONITORING_RESOURCES=true

# --- Reuse mode inputs (only when USE_EXISTING_MONITORING_RESOURCES=true) ---
# Preferred when the App Insights resource is in the target resource group.
# When set, the Log Analytics workspace ID is derived automatically.
EXISTING_APPLICATION_INSIGHTS_NAME=<app-insights-name>

# Or provide explicit resource IDs (use when the resource is in another group).
APPLICATION_INSIGHTS_RESOURCE_ID=
LOG_ANALYTICS_WORKSPACE_ID=

# --- Optional --------------------------------------------------------------
# Route an Azure OpenAI / Cognitive Services account's diagnostics into the
# workspace. Leave blank to skip.
COGNITIVE_SERVICES_ACCOUNT_NAME=<azure-openai-account-name>

# Minimum retention (days) for a newly created workspace.
RETENTION_DAYS=30
