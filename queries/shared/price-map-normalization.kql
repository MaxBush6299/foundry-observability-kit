// Normalizes workbook-provided model price map into query-friendly rows.
// Expected workbook parameter payload: [{"modelKey":"gpt-4o","inputTokenPricePer1k":0.005,"outputTokenPricePer1k":0.015,"currencyCode":"USD","assumptionLabel":"sample"}]
let modelPriceMapJson = todynamic('{"prices": []}');
let prices = modelPriceMapJson.prices;
print prices
| mv-expand price = prices
| project
    modelKey = tostring(price.modelKey),
    inputTokenPricePer1k = todouble(price.inputTokenPricePer1k),
    outputTokenPricePer1k = todouble(price.outputTokenPricePer1k),
    currencyCode = tostring(price.currencyCode),
    assumptionLabel = tostring(price.assumptionLabel)
| where isnotempty(modelKey)
