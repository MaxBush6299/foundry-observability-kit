// Token throughput by deployment and model.
let traceUsage =
    AppDependencies
    | where TimeGenerated > ago(24h)
    | where tostring(Properties['gen_ai.operation.name']) == 'chat'
    | extend modelName = tostring(Properties['gen_ai.request.model'])
    | extend inputTokens = tolong(Properties['gen_ai.usage.input_tokens'])
    | extend outputTokens = tolong(Properties['gen_ai.usage.output_tokens'])
    | summarize inputTokens=sum(inputTokens), outputTokens=sum(outputTokens) by modelName, bin(TimeGenerated, 15m);
traceUsage
| extend totalTokens = inputTokens + outputTokens
| order by TimeGenerated desc
