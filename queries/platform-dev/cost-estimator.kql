// Directional token-cost estimator; not a billing-accurate total.
let modelPriceMap = datatable(modelKey:string, inputTokenPricePer1k:real, outputTokenPricePer1k:real, currencyCode:string, assumptionLabel:string)
[
    'sample-model', 0.005, 0.015, 'USD', 'Directional estimate'
];
let usage =
    AppDependencies
    | where TimeGenerated > ago(24h)
    | where tostring(Properties['gen_ai.operation.name']) == 'chat'
    | extend modelKey = tostring(Properties['gen_ai.request.model'])
    | extend inputTokens = tolong(Properties['gen_ai.usage.input_tokens'])
    | extend outputTokens = tolong(Properties['gen_ai.usage.output_tokens'])
    | summarize inputTokens=sum(inputTokens), outputTokens=sum(outputTokens) by modelKey, bin(TimeGenerated, 1h);
usage
| join kind=leftouter modelPriceMap on modelKey
| extend estimatedInputCost = (todouble(inputTokens) / 1000.0) * inputTokenPricePer1k
| extend estimatedOutputCost = (todouble(outputTokens) / 1000.0) * outputTokenPricePer1k
| extend estimatedTotalCost = estimatedInputCost + estimatedOutputCost
| project TimeGenerated, modelKey, inputTokens, outputTokens, estimatedInputCost, estimatedOutputCost, estimatedTotalCost, currencyCode, assumptionLabel
| order by TimeGenerated desc
